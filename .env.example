# World Labs Marble API Configuration
# Get your API key from https://worldlabs.ai/developer

# Your World Labs API key (required when MOCK_API=false)
WLT_API_KEY=your_api_key_here

# Enable mock mode for development (no API credits used)
# Set to "true" to use mock responses, "false" to hit the real API
MOCK_API=true

# Comma-separated list of hosts to proxy through /api/proxy
# Leave empty or omit if no external hosts need proxying
PROXY_ALLOWED_HOSTS=
